# Database (PostgreSQL)
DATABASE_URL="postgresql://postgres:password@localhost:5432/vizinho"

# Auth.js — generate a secret with: openssl rand -base64 32
AUTH_SECRET="change-me-to-a-long-random-string"
NEXTAUTH_URL="http://localhost:3000"

# Public site URL (used for canonical/OG/sitemap)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

NODE_ENV="development"

# Backblaze B2 (S3-compatible) — file/photo storage
B2_ENDPOINT="https://s3.eu-central-003.backblazeb2.com"
B2_REGION="eu-central-003"
B2_BUCKET="your-bucket-name"
B2_KEY_ID="your-b2-key-id"
B2_APP_KEY="your-b2-application-key"
